# ──────────────────────────────────────────────────────────────────────────
# AI Office — environment variables
# 모두 선택값입니다. 없으면 데모(로컬) 모드로 동작합니다.
# ──────────────────────────────────────────────────────────────────────────

# ── Phase 2: Supabase (인증 + 클라우드 동기화) ──
# Supabase 프로젝트 생성 후 Project Settings → API 에서 복사.
# 그리고 supabase/schema.sql 을 SQL 에디터에서 실행하세요.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Phase 3: Claude 연동 (둘 중 하나만 설정) ──
# (A) 사용량 기반 API 키 — console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=

# (B) 구독 기반 OAuth 토큰 — Claude Pro/Max 구독으로 `claude setup-token` 실행해 발급
#     (API 키가 설정되어 있으면 API 키가 우선합니다)
CLAUDE_OAUTH_TOKEN=

# 선택: 사용할 모델 (기본 claude-haiku-4-5-20251001)
# AI_MODEL=claude-haiku-4-5-20251001
